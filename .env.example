# Copie este arquivo para .env e preencha com valores reais.
# Nenhum valor real deve ser commitado — ver .gitignore.

# ---------------------------------------------------------------------------
# Banco de dados / fila (apps/api)
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/flying_leads"
REDIS_URL="redis://localhost:6379"

# ---------------------------------------------------------------------------
# Google Maps / Places (módulo Google Maps Search — ARCHITECTURE.md §2.1)
# ---------------------------------------------------------------------------
GOOGLE_PLACES_API_KEY=""
GOOGLE_MAPS_JAVASCRIPT_API_KEY=""
GOOGLE_GEOCODING_API_KEY=""

# ---------------------------------------------------------------------------
# IA (IA avaliadora + Gerador de website — ARCHITECTURE.md §2.3, §2.5)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=""
# Opcional — fallback/comparação, não é dependência obrigatória (ver ADR 0002)
OPENAI_API_KEY=""

# ---------------------------------------------------------------------------
# GitHub + Vercel (Deploy automático — ARCHITECTURE.md §2.6)
# ---------------------------------------------------------------------------
GITHUB_TOKEN=""
GITHUB_ORG=""
VERCEL_TOKEN=""
VERCEL_TEAM_ID=""

# ---------------------------------------------------------------------------
# Supabase Auth (autenticação do dashboard)
# ---------------------------------------------------------------------------
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ---------------------------------------------------------------------------
# WhatsApp Business API oficial — só API oficial, nunca automação não
# oficial (ver ADR 0003). Nenhum envio acontece sem aprovação humana.
# ---------------------------------------------------------------------------
WHATSAPP_BUSINESS_API_TOKEN=""
WHATSAPP_BUSINESS_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""

# ---------------------------------------------------------------------------
# apps/web
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL="http://localhost:3000"
