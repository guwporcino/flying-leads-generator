// Modelo inicial — ver ARCHITECTURE.md e packages/shared-types para os
// contratos de aplicação correspondentes a cada model abaixo.
//
// Nenhuma migration foi gerada ainda: este schema deve ser validado contra
// um Postgres real com `pnpm --filter @flying-leads/api prisma:migrate`
// assim que DATABASE_URL estiver disponível (ver TODO.md, Fase 0).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  not_sent
  sent
  viewed
  replied
  interested
  meeting
  customer
  lost
}

enum ContactChannel {
  whatsapp_api
  manual_link
}

enum ContactAttemptStatus {
  sent
  failed
}

model Campaign {
  id           String   @id @default(uuid())
  niche        String
  city         String
  neighborhood String?
  postalCode   String?
  address      String?
  radiusKm     Int
  filters      Json     @default("{}")
  createdAt    DateTime @default(now())

  companies Company[]

  @@map("campaigns")
}

model Company {
  id            String   @id @default(uuid())
  campaignId    String
  name          String
  phone         String?
  whatsapp      String?
  website       String?
  category      String
  openingHours  String?
  reviewCount   Int      @default(0)
  rating        Float?
  photos        String[]
  description   String?
  latitude      Float
  longitude     Float
  googleMapsUrl String
  googlePlaceId String   @unique
  createdAt     DateTime @default(now())

  campaign         Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  websiteAudit     WebsiteAudit?
  opportunityScore OpportunityScore?
  lead             Lead?

  @@index([campaignId])
  @@map("companies")
}

model WebsiteAudit {
  id                    String    @id @default(uuid())
  companyId             String    @unique
  hasWebsite            Boolean
  title                 String?
  description           String?
  detectedTechnology    String[]
  pageCount             Int?
  performanceScore      Int?
  seoScore              Int?
  brokenLinksCount      Int?
  hasHttps              Boolean?
  isResponsive          Boolean?
  loadTimeMs            Int?
  lastUpdatedDetectedAt DateTime?
  copyrightYear         Int?
  socialLinks           String[]
  hasContactForm        Boolean?
  hasMap                Boolean?
  hasBlog               Boolean?
  // Ver WebsiteAuditCriteriaScores / WebsiteAuditFinding[] em @flying-leads/shared-types
  aiCriteriaScores      Json?
  aiGrade               String?
  aiFindings            Json?
  createdAt             DateTime  @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("website_audits")
}

model OpportunityScore {
  id             String   @id @default(uuid())
  companyId      String   @unique
  ruleBasedScore Int
  aiScore        Int?
  finalScore     Int
  reason         String
  computedAt     DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead    Lead?

  @@map("opportunity_scores")
}

model Lead {
  id                 String     @id @default(uuid())
  companyId          String     @unique
  opportunityScoreId String?    @unique
  previewUrl         String?
  approachMessage    String?
  notes              String?
  status             LeadStatus @default(not_sent)
  approvedBy         String?
  approvedAt         DateTime?
  sentAt             DateTime?
  // Follow-up (ver ADR 0013): próxima ação registrada pelo operador; o
  // dashboard lista os vencidos (pull), não há notificação push.
  nextActionAt       DateTime?
  nextActionNote     String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  opportunityScore OpportunityScore? @relation(fields: [opportunityScoreId], references: [id])
  contactAttempts  ContactAttempt[]
  statusEvents     LeadStatusEvent[]

  @@map("leads")
}

/**
 * Histórico de transições do funil de CRM — ver ADR 0013. Uma linha por
 * mudança de status (inclusive not_sent → sent, gravada pelo gate de envio).
 */
model LeadStatusEvent {
  id         String     @id @default(uuid())
  leadId     String
  fromStatus LeadStatus
  toStatus   LeadStatus
  changedBy  String
  createdAt  DateTime   @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([toStatus, createdAt])
  @@map("lead_status_events")
}

/**
 * Histórico de contato — ver ADR 0003 e ADR 0012. Uma linha por tentativa de disparo.
 */
model ContactAttempt {
  id                String               @id @default(uuid())
  leadId            String
  channel           ContactChannel
  status            ContactAttemptStatus
  // channel=whatsapp_api: id da mensagem retornado pela Cloud API.
  // channel=manual_link: o link wa.me montado para o operador abrir manualmente.
  providerMessageId String?
  errorMessage      String?
  createdAt         DateTime             @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("contact_attempts")
}
